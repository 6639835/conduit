{
  "crons": [
    {
      "path": "/api/cron/cleanup-cache",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/check-key-expiration",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/cost-projections",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/aggregate-usage",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/monitor-providers",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/monitor-quotas",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/generate-reports?frequency=daily",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/generate-reports?frequency=weekly",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/generate-reports?frequency=monthly",
      "schedule": "0 9 1 * *"
    },
    {
      "path": "/api/cron/detect-anomalies",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/enforce-retention",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/calculate-sla",
      "schedule": "0 * * * *"
    }
  ]
}
